{
  "name": "nahidarbx",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NAHIDARBX_ENGINE=1 next dev",
    "engine": "NAHIDARBX_ENGINE=1 tsx engine.ts",
    "dev:all": "rm -rf /tmp/nahidarbx-boot && NAHIDARBX_UNIFIED_BOOT=1 npm run engine & NAHIDARBX_UNIFIED_BOOT=1 npm run ai-search & sleep 2 && NAHIDARBX_UNIFIED_BOOT=1 npm run dev",
    "engine:stop": "pkill -f 'tsx engine.ts' || echo 'No engine running'",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "clean": "rm -rf .next && rm -f ~/package.json && echo '✓ Cleared .next cache and stray ~/package.json'",
    "kill": "node scripts/kill-dev.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "deploy": "echo '🔨 Building...' && NODE_ENV=production npm run build && echo '✅ Build complete!' && echo '🚀 Starting server with PM2...' && pm2 delete nahidarbx 2>/dev/null || true && pm2 start ecosystem.config.js --env production && echo '✅ Deploy complete!' && pm2 list",
    "pm2:start": "pm2 start ecosystem.config.js --env production && pm2 list",
    "pm2:stop": "pm2 delete all && pm2 list",
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:headed": "npx playwright test --headed",
    "test:report": "npx playwright show-report",
    "test:login": "npx playwright test e2e/login.spec.ts",
    "test:admin": "npx playwright test e2e/admin.spec.ts",
    "test:api": "npx playwright test e2e/api-health.spec.ts",
    "test:nav": "npx playwright test e2e/navigation.spec.ts",
    "test:ml-ui": "tsx scripts/test-ml-ui-pipeline.ts",
    "test:settle": "node --import tsx --test lib/settle/*.test.ts",
    "test:unit": "node --import tsx --test lib/**/*.test.ts",
    "ai-search": "tsx scripts/ai-search-supervisor.ts",
    "ml:verify": "tsx scripts/ml-verify.ts",
    "ml:verify:contract": "tsx scripts/ml-verify.ts contract",
    "ai-search:raw": "cd services/ai-search && source .venv/bin/activate && uvicorn app.main:app --host 0.0.0.0 --port 8090 --reload"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google-cloud/cloud-sql-connector": "^1.10.0",
    "@google-cloud/run": "^3.2.1",
    "@google-cloud/storage": "^7.19.0",
    "@google/genai": "^1.50.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-switch": "^1.2.6",
    "@react-email/render": "^2.0.8",
    "@stomp/stompjs": "^7.3.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.18",
    "axios": "^1.13.4",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cockatiel": "^3.2.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.1",
    "embla-carousel-react": "^8.6.0",
    "google-auth-library": "^10.6.2",
    "jose": "^6.1.3",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^0.563.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "onnxruntime-node": "^1.25.1",
    "openai": "^6.35.0",
    "p-limit": "^6.2.0",
    "pg": "^8.20.0",
    "playwright": "^1.58.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.1",
    "resend": "^6.1.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/string-similarity": "^4.0.2",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4",
    "ws": "^8.20.0"
  }
}
